# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=backend=debug,tower_http=debug

# Database PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/myapp_db
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=900        # 15 menit (detik)
JWT_REFRESH_EXPIRES_IN=604800    # 7 hari (detik)

# CORS (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# App
APP_ENV=development
